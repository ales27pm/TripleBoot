# TripleBoot environment/defaults example
# Copy this file to ~/.config/tripleboot/defaults.env, source it manually, or use:
#   sudo -E scripts/tripleboot_aio.sh configure-defaults

# Main working directory
TRIPLEBOOT_WORKDIR="$HOME/tripleboot-aio"

# Backup, inventory, build, download, and log paths
TRIPLEBOOT_BACKUP_ROOT="$HOME/tripleboot-aio/backups"
TRIPLEBOOT_INVENTORY_DIR="$HOME/tripleboot-aio/inventory"
TRIPLEBOOT_BUILD_DIR="$HOME/tripleboot-aio/build"
TRIPLEBOOT_DOWNLOAD_DIR="$HOME/tripleboot-aio/downloads"
TRIPLEBOOT_LOG_DIR="$HOME/tripleboot-aio/logs"

# Partition sizes
EFI_SIZE="1024MiB"
WINDOWS_SIZE="500GiB"
UBUNTU_SWAP_SIZE="32G"

# Saved disk and installer defaults used by the menu/default-* shortcuts
UBUNTU_DISK="/dev/nvme0n1"
WINMAC_DISK="/dev/nvme1n1"
USB_DISK="/dev/sdX"
WINDOWS_ISO="$HOME/Downloads/Windows11.iso"
WINDOWS_ISO_URL=""

# Ubuntu installer defaults
UBUNTU_VERSION="26.04"
UBUNTU_EDITION="desktop"
UBUNTU_ARCH="amd64"

# Optional USB payload defaults
INCLUDE_OPENCORE="true"
INCLUDE_OSX_KVM="false"
OPENCORE_SMBIOS="iMac20,1"
OPENCORE_GPU_POLICY="disable-nvidia"
OSX_KVM_DIR="$HOME/OSX-KVM"

# Optional autonomous profile defaults
AUTONOMOUS_PROFILE="profiles/pc-27pm.yml"
AUTONOMOUS_OUTPUT="$HOME/tripleboot-aio/build/autonomous-payload"

# Example usage:
# source examples/tripleboot.env.example
# sudo -E scripts/tripleboot_aio.sh menu
# sudo -E scripts/tripleboot_aio.sh show-defaults
# sudo -E scripts/tripleboot_aio.sh default-preflight-partition
